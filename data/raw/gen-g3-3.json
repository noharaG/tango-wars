[
  {"word":"eager","pos":"adj","ja":"熱心な、切望している","level":3,"cat":"general","ipa":"/ˈiːɡər/","ex":"She was eager to start her new job at the robotics company.","exJa":"彼女はロボット会社での新しい仕事を始めることに意欲的だった。","collocations":["eager to","eager for"],"synonyms":["keen","enthusiastic"],"distractorHint":["冷静な","疲れた","消極的な"]},
  {"word":"earnest","pos":"adj","ja":"真剣な、誠実な","level":3,"cat":"general","ipa":"/ˈɜːrnɪst/","ex":"He made an earnest effort to fix the broken sensor.","exJa":"彼は壊れたセンサーを修理しようと真剣に努力した。","collocations":["earnest effort","in earnest"],"synonyms":["sincere","serious"],"distractorHint":["軽率な","うわべだけの","面白い"]},
  {"word":"edge","pos":"n","ja":"優位、端","level":3,"cat":"general","ipa":"/edʒ/","ex":"The new algorithm gives our team a competitive edge.","exJa":"その新しいアルゴリズムは私たちのチームに競争上の優位を与える。","collocations":["competitive edge","cutting edge"],"synonyms":["advantage","border"],"distractorHint":["欠点","中心","遅れ"]},
  {"word":"efficient","pos":"adj","ja":"効率的な","level":3,"cat":"general","ipa":"/ɪˈfɪʃənt/","ex":"This motor is more efficient than the old model.","exJa":"このモーターは古いモデルより効率的だ。","collocations":["energy efficient","efficient use"],"synonyms":["effective","productive"],"distractorHint":["無駄な","高価な","遅い"]},
  {"word":"elaborate","pos":"v","ja":"詳しく説明する、精巧な","level":3,"cat":"general","ipa":"/ɪˈlæbəreɪt/","ex":"Could you elaborate on how the mechanism works?","exJa":"その機構がどう動くのか、もう少し詳しく説明してもらえますか。","collocations":["elaborate on","elaborate plan"],"synonyms":["explain","detail"],"distractorHint":["省略する","単純化する","隠す"]},
  {"word":"eliminate","pos":"v","ja":"排除する、取り除く","level":3,"cat":"general","ipa":"/ɪˈlɪmɪneɪt/","ex":"We need to eliminate this bug before the competition.","exJa":"大会の前にこのバグを取り除く必要がある。","collocations":["eliminate risk","eliminate errors"],"synonyms":["remove","get rid of"],"distractorHint":["追加する","修正する","保存する"]},
  {"word":"embarrass","pos":"v","ja":"恥ずかしがらせる、困惑させる","level":3,"cat":"general","ipa":"/ɪmˈbærəs/","ex":"He felt embarrassed when the robot failed in front of everyone.","exJa":"みんなの前でロボットが失敗して彼は恥ずかしくなった。","collocations":["feel embarrassed","embarrass someone"],"synonyms":["humiliate","shame"],"distractorHint":["感動させる","励ます","満足させる"]},
  {"word":"emerge","pos":"v","ja":"現れる、浮上する","level":3,"cat":"general","ipa":"/ɪˈmɜːrdʒ/","ex":"A new problem emerged during the final testing phase.","exJa":"最終テストの段階で新しい問題が現れた。","collocations":["emerge from","emerge as"],"synonyms":["appear","arise"],"distractorHint":["消える","解決する","沈む"]},
  {"word":"emphasize","pos":"v","ja":"強調する","level":3,"cat":"general","ipa":"/ˈemfəsaɪz/","ex":"The coach emphasized the importance of teamwork.","exJa":"コーチはチームワークの重要性を強調した。","collocations":["emphasize the need","heavily emphasize"],"synonyms":["stress","highlight"],"distractorHint":["無視する","軽視する","疑う"]},
  {"word":"enable","pos":"v","ja":"可能にする","level":3,"cat":"general","ipa":"/ɪˈneɪbəl/","ex":"This sensor enables the robot to detect obstacles.","exJa":"このセンサーはロボットが障害物を検知することを可能にする。","collocations":["enable someone to","enable access"],"synonyms":["allow","permit"],"distractorHint":["禁止する","妨げる","削除する"]},
  {"word":"encounter","pos":"v","ja":"遭遇する","level":3,"cat":"general","ipa":"/ɪnˈkaʊntər/","ex":"We encountered several technical issues during the build season.","exJa":"ビルドシーズン中に私たちはいくつかの技術的な問題に遭遇した。","collocations":["encounter difficulty","encounter a problem"],"synonyms":["face","come across"],"distractorHint":["避ける","解決する","予測する"]},
  {"word":"endure","pos":"v","ja":"耐える、持続する","level":3,"cat":"general","ipa":"/ɪnˈdʊr/","ex":"The battery must endure extreme temperatures during the match.","exJa":"バッテリーは試合中の極端な温度に耐えなければならない。","collocations":["endure hardship","endure pain"],"synonyms":["withstand","tolerate"],"distractorHint":["避ける","拒否する","破壊する"]},
