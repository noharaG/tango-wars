  {"word":"stagnant","pos":"adj","ja":"停滞した、よどんだ","level":3,"cat":"general","ipa":"/ˈstæɡnənt/","ex":"The economy has remained stagnant for the past decade.","exJa":"経済はこの十年間停滞したままだ。","collocations":["stagnant economy","stagnant water"],"synonyms":["motionless","sluggish"],"distractorHint":["急成長する","流動的な","安定した"]},
  {"word":"stark","pos":"adj","ja":"厳しい、明白な","level":3,"cat":"general","ipa":"/stɑːrk/","ex":"There is a stark contrast between the two proposals.","exJa":"二つの提案には明白な対照がある。","collocations":["stark contrast","stark reality"],"synonyms":["harsh","clear"],"distractorHint":["曖昧な","豊かな","柔らかい"]},
  {"word":"stern","pos":"adj","ja":"厳格な、厳しい","level":3,"cat":"general","ipa":"/stɜːrn/","ex":"Her father gave her a stern warning about the curfew.","exJa":"彼女の父は門限について厳しい警告をした。","collocations":["stern warning","stern look"],"synonyms":["strict","severe"],"distractorHint":["優しい","陽気な","無関心な"]},
  {"word":"stray","pos":"v","ja":"はぐれる、逸れる","level":3,"cat":"general","ipa":"/streɪ/","ex":"The conversation strayed from the original topic quickly.","exJa":"会話はすぐに元の話題から逸れてしまった。","collocations":["stray from","stray dog"],"synonyms":["wander","deviate"],"distractorHint":["集中する","戻る","計画する"]},
  {"word":"stringent","pos":"adj","ja":"厳しい、厳格な","level":3,"cat":"general","ipa":"/ˈstrɪndʒənt/","ex":"The factory now follows stringent safety regulations.","exJa":"その工場は今、厳しい安全規則に従っている。","collocations":["stringent rules","stringent standards"],"synonyms":["strict","rigorous"],"distractorHint":["緩やかな","任意の","無効な"]},
  {"word":"stumble","pos":"v","ja":"つまずく、口ごもる","level":3,"cat":"general","ipa":"/ˈstʌmbəl/","ex":"He stumbled over his words during the nervous interview.","exJa":"緊張した面接中、彼は言葉につまずいた。","collocations":["stumble over","stumble upon"],"synonyms":["trip","falter"],"distractorHint":["流暢に話す","走る","成功する"]},
  {"word":"subtle","pos":"adj","ja":"微妙な、繊細な","level":3,"cat":"general","ipa":"/ˈsʌtəl/","ex":"There was a subtle change in her tone during the call.","exJa":"電話中、彼女の口調にはかすかな変化があった。","collocations":["subtle difference","subtle hint"],"synonyms":["slight","nuanced"],"distractorHint":["明白な","粗野な","巨大な"]}
