[
  {"word":"qualify","pos":"v","ja":"資格を得る、適格とする","level":3,"cat":"general","ipa":"/ˈkwɒlɪfaɪ/","ex":"She had to study hard to qualify as a lawyer.","exJa":"弁護士の資格を得るため彼女は熱心に勉強しなければならなかった。","collocations":["qualify for","qualify as"],"synonyms":["certify","entitle"],"distractorHint":["否定する","辞退する","分類する"]},
  {"word":"quote","pos":"v","ja":"引用する、見積もる","level":3,"cat":"general","ipa":"/kwoʊt/","ex":"He quoted a famous line from Shakespeare in his speech.","exJa":"彼はスピーチでシェイクスピアの有名な一節を引用した。","collocations":["quote from","quote a price"],"synonyms":["cite"],"distractorHint":["翻訳する","要約する","否定する"]},
  {"word":"query","pos":"n","ja":"質問、疑問","level":3,"cat":"general","ipa":"/ˈkwɪəri/","ex":"I have a query about the new billing system.","exJa":"新しい請求システムについて質問があります。","collocations":["raise a query","answer a query"],"synonyms":["question","inquiry"],"distractorHint":["回答","抗議","誤り"]},
  {"word":"quest","pos":"n","ja":"探求、探索","level":3,"cat":"general","ipa":"/kwest/","ex":"The team went on a quest to find a cure for the disease.","exJa":"そのチームは病気の治療法を探す探求に乗り出した。","collocations":["quest for","embark on a quest"],"synonyms":["search","pursuit"],"distractorHint":["疑問","要求","任務失敗"]},
  {"word":"quirk","pos":"n","ja":"癖、特異な点","level":3,"cat":"general","ipa":"/kwɜːrk/","ex":"Forgetting names is just one of his little quirks.","exJa":"名前を忘れるのは彼のちょっとした癖の一つに過ぎない。","collocations":["personality quirk","quirk of fate"],"synonyms":["peculiarity","eccentricity"],"distractorHint":["欠点","才能","運命"]},
  {"word":"reluctant","pos":"adj","ja":"気が進まない、不本意な","level":3,"cat":"general","ipa":"/rɪˈlʌktənt/","ex":"He was reluctant to admit that he had made a mistake.","exJa":"彼はミスを認めるのに気が進まなかった。","collocations":["reluctant to do","reluctant admission"],"synonyms":["unwilling","hesitant"],"distractorHint":["熱心な","反抗的な","後悔した"]},
  {"word":"resilient","pos":"adj","ja":"回復力のある、粘り強い","level":3,"cat":"general","ipa":"/rɪˈzɪliənt/","ex":"Children are often surprisingly resilient after difficult experiences.","exJa":"子供たちは困難な経験の後でも驚くほど回復力があることが多い。","collocations":["resilient economy","emotionally resilient"],"synonyms":["tough","adaptable"],"distractorHint":["弱々しい","従順な","柔軟性のない"]},
  {"word":"retrieve","pos":"v","ja":"取り戻す、検索する","level":3,"cat":"general","ipa":"/rɪˈtriːv/","ex":"The dog was trained to retrieve the ball from the water.","exJa":"その犬は水からボールを取ってくるよう訓練された。","collocations":["retrieve information","retrieve data"],"synonyms":["recover","fetch"],"distractorHint":["捨てる","隠す","保存する"]},
  {"word":"revenue","pos":"n","ja":"収益、税収","level":3,"cat":"general","ipa":"/ˈrevənuː/","ex":"The company's annual revenue increased by ten percent this year.","exJa":"その会社の年間収益は今年10パーセント増加した。","collocations":["generate revenue","tax revenue"],"synonyms":["income","earnings"],"distractorHint":["支出","負債","予算"]},
  {"word":"robust","pos":"adj","ja":"頑丈な、力強い","level":3,"cat":"general","ipa":"/roʊˈbʌst/","ex":"We need a more robust system to handle these errors.","exJa":"これらのエラーに対応するにはより頑丈なシステムが必要だ。","collocations":["robust design","robust economy"],"synonyms":["sturdy","strong"],"distractorHint":["脆弱な","柔らかい","単純な"]},
  {"word":"rigorous","pos":"adj","ja":"厳密な、厳格な","level":3,"cat":"general","ipa":"/ˈrɪɡərəs/","ex":"The medicine went through rigorous testing before approval.","exJa":"その薬は承認前に厳密な試験を受けた。","collocations":["rigorous testing","rigorous analysis"],"synonyms":["strict","thorough"],"distractorHint":["緩い","迅速な","慎重でない"]},
  {"word":"rigid","pos":"adj","ja":"硬直した、厳格な","level":3,"cat":"general","ipa":"/ˈrɪdʒɪd/","ex":"The old rules were too rigid to fit modern needs.","exJa":"昔の規則は現代の需要に合わせるには硬直しすぎていた。","collocations":["rigid rules","rigid structure"],"synonyms":["stiff","inflexible"],"distractorHint":["柔軟な","丈夫な","公平な"]},
  {"word":"resolve","pos":"v","ja":"解決する、決意する","level":3,"cat":"general","ipa":"/rɪˈzɒlv/","ex":"They finally resolved the dispute after months of talks.","exJa":"数か月の話し合いの末、彼らはついに争いを解決した。","collocations":["resolve a conflict","resolve to do"],"synonyms":["settle","determine"],"distractorHint":["悪化させる","無視する","延期する"]},
  {"word":"refine","pos":"v","ja":"精製する、洗練する","level":3,"cat":"general","ipa":"/rɪˈfaɪn/","ex":"She spent years refining her technique as a painter.","exJa":"彼女は画家としての技法を洗練させるのに何年もかけた。","collocations":["refine a process","refine oil"],"synonyms":["improve","polish"],"distractorHint":["拒否する","反映する","簡略化する"]},
  {"word":"refute","pos":"v","ja":"論破する、反証する","level":3,"cat":"general","ipa":"/rɪˈfjuːt/","ex":"The scientist presented data to refute the earlier claim.","exJa":"その科学者は以前の主張を論破するデータを示した。","collocations":["refute a claim","refute an argument"],"synonyms":["disprove","rebut"],"distractorHint":["支持する","拒絶する","反省する"]},
  {"word":"reckon","pos":"v","ja":"思う、見積もる","level":3,"cat":"general","ipa":"/ˈrekən/","ex":"I reckon we should leave before the traffic gets worse.","exJa":"交通が悪化する前に出発すべきだと思う。","collocations":["reckon with","reckon that"],"synonyms":["think","estimate"],"distractorHint":["後悔する","記録する","認識しない"]},
  {"word":"recur","pos":"v","ja":"再発する、繰り返し起こる","level":3,"cat":"general","ipa":"/rɪˈkɜːr/","ex":"The pain in his knee recurs every time it rains.","exJa":"雨が降るたびに彼の膝の痛みが再発する。","collocations":["recur frequently","recurring problem"],"synonyms":["reappear","repeat"],"distractorHint":["治る","消える","発生を防ぐ"]},
  {"word":"redundant","pos":"adj","ja":"余分な、冗長な","level":3,"cat":"general","ipa":"/rɪˈdʌndənt/","ex":"Half of the sentence was redundant and could be deleted.","exJa":"その文の半分は冗長で削除できた。","collocations":["redundant information","made redundant"],"synonyms":["superfluous","excessive"],"distractorHint":["不十分な","重要な","簡潔な"]},
  {"word":"refrain","pos":"v","ja":"控える、慎む","level":3,"cat":"general","ipa":"/rɪˈfreɪn/","ex":"Please refrain from talking during the presentation.","exJa":"発表中は話すことを控えてください。","collocations":["refrain from doing"],"synonyms":["abstain","avoid"],"distractorHint":["繰り返す","強制する","参加する"]},
  {"word":"relevant","pos":"adj","ja":"関連のある、妥当な","level":3,"cat":"general","ipa":"/ˈreləvənt/","ex":"Please include only relevant information in the report.","exJa":"報告書には関連のある情報だけを含めてください。","collocations":["relevant to","highly relevant"],"synonyms":["pertinent","applicable"],"distractorHint":["無関係な","過剰な","反対の"]},
  {"word":"render","pos":"v","ja":"~にする、提供する","level":3,"cat":"general","ipa":"/ˈrendər/","ex":"The injury rendered him unable to walk for weeks.","exJa":"その負傷のせいで彼は数週間歩けなくなった。","collocations":["render useless","render a service"],"synonyms":["make","cause to become"],"distractorHint":["修理する","無視する","改善する"]},
  {"word":"renowned","pos":"adj","ja":"有名な、名高い","level":3,"cat":"general","ipa":"/rɪˈnaʊnd/","ex":"The city is renowned for its ancient temples.","exJa":"その都市は古代の寺院で有名だ。","collocations":["renowned for","world-renowned"],"synonyms":["famous","celebrated"],"distractorHint":["無名の","悪名高い","疑わしい"]},
  {"word":"replicate","pos":"v","ja":"再現する、複製する","level":3,"cat":"general","ipa":"/ˈreplɪkeɪt/","ex":"Researchers tried to replicate the results of the experiment.","exJa":"研究者たちはその実験結果を再現しようとした。","collocations":["replicate a study","replicate results"],"synonyms":["reproduce","duplicate"],"distractorHint":["反論する","修正する","破棄する"]},
  {"word":"resent","pos":"v","ja":"憤慨する、恨む","level":3,"cat":"general","ipa":"/rɪˈzent/","ex":"She resented being told what to do all the time.","exJa":"彼女はいつも指示されることに憤慨していた。","collocations":["resent something","deeply resent"],"synonyms":["dislike","begrudge"],"distractorHint":["感謝する","無視する","後悔する"]},
  {"word":"reside","pos":"v","ja":"居住する、存在する","level":3,"cat":"general","ipa":"/rɪˈzaɪd/","ex":"Many engineers from abroad reside in this city.","exJa":"多くの外国出身の技術者がこの都市に居住している。","collocations":["reside in","power resides in"],"synonyms":["live","dwell"],"distractorHint":["訪問する","移住する準備","去る"]},
  {"word":"resign","pos":"v","ja":"辞任する、辞職する","level":3,"cat":"general","ipa":"/rɪˈzaɪn/","ex":"The manager decided to resign after the scandal.","exJa":"そのマネージャーは不正発覚後に辞任することを決めた。","collocations":["resign from","resign as"],"synonyms":["quit","step down"],"distractorHint":["就任する","解雇する","昇進する"]},
  {"word":"restrain","pos":"v","ja":"抑制する、制止する","level":3,"cat":"general","ipa":"/rɪˈstreɪn/","ex":"He could barely restrain his anger during the meeting.","exJa":"彼は会議中怒りを抑えるのがやっとだった。","collocations":["restrain oneself","restrain from"],"synonyms":["control","hold back"],"distractorHint":["表現する","促進する","解放する"]},
  {"word":"retain","pos":"v","ja":"保持する、維持する","level":3,"cat":"general","ipa":"/rɪˈteɪn/","ex":"The company worked hard to retain its best employees.","exJa":"その会社は優秀な社員を維持するために努力した。","collocations":["retain customers","retain information"],"synonyms":["keep","preserve"],"distractorHint":["解雇する","獲得する","放棄する"]},
  {"word":"reveal","pos":"v","ja":"明らかにする、暴露する","level":3,"cat":"general","ipa":"/rɪˈviːl/","ex":"The survey revealed that most users wanted a simpler design.","exJa":"調査により大半の利用者がより簡単な設計を望んでいることが明らかになった。","collocations":["reveal the truth","newly revealed"],"synonyms":["disclose","expose"],"distractorHint":["隠す","予測する","確認する"]},
  {"word":"revise","pos":"v","ja":"修正する、改訂する","level":3,"cat":"general","ipa":"/rɪˈvaɪz/","ex":"We need to revise the schedule to meet the new deadline.","exJa":"新しい締め切りに間に合わせるため予定を修正する必要がある。","collocations":["revise a plan","thoroughly revised"],"synonyms":["amend","edit"],"distractorHint":["承認する","無効にする","作成する"]},
  {"word":"rhetoric","pos":"n","ja":"修辞、美辞麗句","level":3,"cat":"general","ipa":"/ˈretərɪk/","ex":"His speech was full of rhetoric but lacked concrete plans.","exJa":"彼の演説は美辞麗句ばかりで具体的な計画がなかった。","collocations":["political rhetoric","empty rhetoric"],"synonyms":["oratory"],"distractorHint":["論理","証拠","誠実さ"]},
  {"word":"ripple","pos":"n","ja":"さざ波、波紋、影響","level":3,"cat":"general","ipa":"/ˈrɪpəl/","ex":"The announcement sent ripples of concern through the market.","exJa":"その発表は市場に懸念の波紋を広げた。","collocations":["ripple effect","send ripples"],"synonyms":["wave","effect"],"distractorHint":["嵐","洪水","静寂"]},
  {"word":"salient","pos":"adj","ja":"顕著な、目立つ","level":3,"cat":"general","ipa":"/ˈseɪliənt/","ex":"Let me summarize the most salient points of the report.","exJa":"報告書の最も重要な点をまとめさせてください。","collocations":["salient point","salient feature"],"synonyms":["prominent","notable"],"distractorHint":["些細な","隠れた","一般的な"]},
  {"word":"sanction","pos":"n","ja":"制裁、認可","level":3,"cat":"general","ipa":"/ˈsæŋkʃən/","ex":"The country faced economic sanctions after the invasion.","exJa":"その国は侵攻後に経済制裁を受けた。","collocations":["impose sanctions","economic sanction"],"synonyms":["penalty","embargo"],"distractorHint":["援助","報酬","撤回"]},
  {"word":"scarce","pos":"adj","ja":"不足している、まれな","level":3,"cat":"general","ipa":"/skeərs/","ex":"Clean water became scarce during the long drought.","exJa":"長い干ばつの間、きれいな水が不足するようになった。","collocations":["scarce resources","increasingly scarce"],"synonyms":["rare","limited"],"distractorHint":["豊富な","安価な","有害な"]},
  {"word":"scrutiny","pos":"n","ja":"精査、監視","level":3,"cat":"general","ipa":"/ˈskruːtəni/","ex":"The company's finances came under close scrutiny.","exJa":"その会社の財務は厳しい精査を受けた。","collocations":["under scrutiny","public scrutiny"],"synonyms":["examination","inspection"],"distractorHint":["賞賛","無視","承認"]},
  {"word":"sequel","pos":"n","ja":"続編、結果","level":3,"cat":"general","ipa":"/ˈsiːkwəl/","ex":"The movie's sequel was even more popular than the original.","exJa":"その映画の続編は元の作品よりさらに人気があった。","collocations":["long-awaited sequel","sequel to"],"synonyms":["follow-up"],"distractorHint":["前編","要約","結末"]},
  {"word":"skeptical","pos":"adj","ja":"懐疑的な","level":3,"cat":"general","ipa":"/ˈskeptɪkəl/","ex":"Many investors remained skeptical about the new startup.","exJa":"多くの投資家はその新興企業に懐疑的なままだった。","collocations":["skeptical of","remain skeptical"],"synonyms":["doubtful","dubious"],"distractorHint":["確信している","楽観的な","無関心な"]},
