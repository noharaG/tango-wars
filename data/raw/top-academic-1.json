[
  {"word":"abrogate","pos":"v","ja":"廃止する、撤廃する","level":5,"cat":"academic","ipa":"/ˈæbrəɡeɪt/","ex":"The government decided to abrogate the outdated trade treaty.","exJa":"政府は古い貿易協定を廃止することを決定した。","collocations":["abrogate a treaty","abrogate a law","abrogate responsibility"],"synonyms":["repeal","rescind","annul"],"distractorHint":["承認する","修正する","延長する"]},
  {"word":"accretion","pos":"n","ja":"徐々の増大、付加物","level":5,"cat":"academic","ipa":"/əˈkriːʃən/","ex":"Sediment accretion gradually formed a new delta at the river mouth.","exJa":"堆積物の徐々の増大が河口に新しい三角州を形成した。","collocations":["gradual accretion","accretion of wealth","accretion disk"],"synonyms":["accumulation","buildup"],"distractorHint":["急激な減少","分解","浸食"]},
  {"word":"adjudicate","pos":"v","ja":"裁定する、判決を下す","level":5,"cat":"academic","ipa":"/əˈdʒuːdɪkeɪt/","ex":"An independent panel will adjudicate the dispute between the two firms.","exJa":"独立した審査委員会が両社間の紛争を裁定する。","collocations":["adjudicate a dispute","adjudicate a claim","panel to adjudicate"],"synonyms":["arbitrate","rule","judge"],"distractorHint":["交渉する","無視する","延期する"]},
  {"word":"admonish","pos":"v","ja":"戒める、忠告する","level":5,"cat":"academic","ipa":"/ədˈmɒnɪʃ/","ex":"The professor gently admonished the students for missing deadlines.","exJa":"教授は締め切りを守らなかった学生たちを穏やかに戒めた。","collocations":["admonish someone for","gently admonish","admonish sternly"],"synonyms":["reprimand","chide","rebuke"],"distractorHint":["褒める","無視する","解雇する"]},
  {"word":"adumbrate","pos":"v","ja":"予示する、概要を示す","level":5,"cat":"academic","ipa":"/ˈædʌmbreɪt/","ex":"The introduction adumbrates the main arguments developed later in the thesis.","exJa":"序論は論文で後に展開される主要な論点を予示している。","collocations":["adumbrate an idea","adumbrate a theory","briefly adumbrate"],"synonyms":["outline","foreshadow","sketch"],"distractorHint":["詳細に説明する","否定する","結論づける"]},
  {"word":"aggrandize","pos":"v","ja":"拡大する、誇張する","level":5,"cat":"academic","ipa":"/əˈɡrændaɪz/","ex":"The dictator used the ceremony to aggrandize his own image.","exJa":"独裁者はその式典を利用して自分の権威を誇張した。","collocations":["self-aggrandize","aggrandize power","aggrandize one's reputation"],"synonyms":["exaggerate","magnify","inflate"],"distractorHint":["謙遜する","縮小する","無視する"]},
  {"word":"ameliorate","pos":"v","ja":"改善する","level":5,"cat":"academic","ipa":"/əˈmiːliəreɪt/","ex":"New policies were introduced to ameliorate the workers' living conditions.","exJa":"労働者の生活状況を改善するために新しい政策が導入された。","collocations":["ameliorate conditions","ameliorate the situation","seek to ameliorate"],"synonyms":["improve","alleviate","enhance"],"distractorHint":["悪化させる","無視する","放棄する"]},
  {"word":"anachronism","pos":"n","ja":"時代錯誤","level":5,"cat":"academic","ipa":"/əˈnækrənɪzəm/","ex":"Critics called the outdated policy an anachronism in modern society.","exJa":"批評家たちはその古い政策を現代社会における時代錯誤と呼んだ。","collocations":["a glaring anachronism","historical anachronism","seem like an anachronism"],"synonyms":["throwback"],"distractorHint":["先進性","革新","伝統の継承"]},
  {"word":"antecedent","pos":"n","ja":"先行するもの、前例","level":5,"cat":"academic","ipa":"/ˌæntɪˈsiːdənt/","ex":"Researchers traced the historical antecedents of the modern legal system.","exJa":"研究者たちは現代の法制度の歴史的先例をたどった。","collocations":["historical antecedent","antecedent event","lack an antecedent"],"synonyms":["precursor","forerunner"],"distractorHint":["結果","後継者","副産物"]},
  {"word":"antithesis","pos":"n","ja":"対照、正反対","level":5,"cat":"academic","ipa":"/ænˈtɪθəsɪs/","ex":"Her calm demeanor was the antithesis of her brother's fiery temper.","exJa":"彼女の落ち着いた態度は弟の激しい気性と正反対だった。","collocations":["the antithesis of","stark antithesis","serve as an antithesis"],"synonyms":["opposite","converse"],"distractorHint":["類似点","統合","強調"]},
  {"word":"apathy","pos":"n","ja":"無関心","level":5,"cat":"academic","ipa":"/ˈæpəθi/","ex":"Voter apathy has been rising steadily over the past decade.","exJa":"有権者の無関心はこの10年間で着実に高まっている。","collocations":["voter apathy","widespread apathy","public apathy"],"synonyms":["indifference","detachment"],"distractorHint":["熱意","同情","反発"]},
  {"word":"apocryphal","pos":"adj","ja":"出典が疑わしい、真偽不明の","level":5,"cat":"academic","ipa":"/əˈpɒkrɪfəl/","ex":"The story about the professor's dramatic resignation is probably apocryphal.","exJa":"その教授の劇的な辞職についての話はおそらく作り話である。","collocations":["apocryphal story","apocryphal anecdote","widely apocryphal"],"synonyms":["dubious","unverified"],"distractorHint":["公式に認められた","証明済みの","有名な"]},
  {"word":"appease","pos":"v","ja":"なだめる、宥和する","level":5,"cat":"academic","ipa":"/əˈpiːz/","ex":"The company offered refunds to appease angry customers.","exJa":"会社は怒った顧客をなだめるために返金を提案した。","collocations":["appease critics","appease anger","attempt to appease"],"synonyms":["placate","pacify","mollify"],"distractorHint":["挑発する","無視する","訴える"]},
  {"word":"arduous","pos":"adj","ja":"困難で骨の折れる","level":5,"cat":"academic","ipa":"/ˈɑːrdʒuəs/","ex":"Completing the doctoral dissertation was an arduous, years-long process.","exJa":"博士論文を完成させるのは数年に及ぶ困難な過程だった。","collocations":["arduous task","arduous journey","arduous process"],"synonyms":["laborious","strenuous","grueling"],"distractorHint":["容易な","楽しい","単純な"]},
  {"word":"ascetic","pos":"adj","ja":"禁欲的な","level":5,"cat":"academic","ipa":"/əˈsɛtɪk/","ex":"The monk led an ascetic life, owning almost nothing.","exJa":"その僧はほとんど何も所有しない禁欲的な生活を送った。","collocations":["ascetic lifestyle","ascetic monk","live an ascetic life"],"synonyms":["austere","self-denying"],"distractorHint":["贅沢な","社交的な","享楽的な"]},
  {"word":"assiduous","pos":"adj","ja":"勤勉な、こつこつ励む","level":5,"cat":"academic","ipa":"/əˈsɪdʒuəs/","ex":"She was assiduous in reviewing every line of the manuscript.","exJa":"彼女は原稿の一行一行を勤勉に見直した。","collocations":["assiduous effort","assiduous student","remain assiduous"],"synonyms":["diligent","industrious"],"distractorHint":["怠惰な","短気な","無関心な"]},
  {"word":"attenuate","pos":"v","ja":"減弱させる、薄める","level":5,"cat":"academic","ipa":"/əˈtɛnjueɪt/","ex":"The thick wall helps attenuate noise from the street outside.","exJa":"厚い壁は外の道路からの騒音を減弱させるのに役立つ。","collocations":["attenuate the signal","attenuate risk","attenuate noise"],"synonyms":["weaken","diminish","reduce"],"distractorHint":["増幅する","反射する","記録する"]},
  {"word":"austere","pos":"adj","ja":"厳格な、簡素な","level":5,"cat":"academic","ipa":"/ɒˈstɪər/","ex":"The dormitory rooms were austere, with only a bed and a desk.","exJa":"寮の部屋は簡素で、ベッドと机しかなかった。","collocations":["austere lifestyle","austere measures","austere interior"],"synonyms":["stark","spartan","severe"],"distractorHint":["豪華な","快適な","装飾的な"]},
  {"word":"autonomy","pos":"n","ja":"自律性、自治","level":5,"cat":"academic","ipa":"/ɔːˈtɒnəmi/","ex":"The research team was granted considerable autonomy over its budget.","exJa":"研究チームは予算に関してかなりの自律性を与えられた。","collocations":["grant autonomy","regional autonomy","exercise autonomy"],"synonyms":["independence","self-governance"],"distractorHint":["依存","統制","服従"]},
  {"word":"aversion","pos":"n","ja":"嫌悪、反感","level":5,"cat":"academic","ipa":"/əˈvɜːrʒən/","ex":"Many students have an aversion to public speaking.","exJa":"多くの学生は人前で話すことに嫌悪感を持っている。","collocations":["aversion to risk","strong aversion","develop an aversion"],"synonyms":["dislike","distaste","repulsion"],"distractorHint":["愛着","興味","習慣"]},
  {"word":"axiomatic","pos":"adj","ja":"自明の、公理的な","level":5,"cat":"academic","ipa":"/ˌæksiəˈmætɪk/","ex":"It is almost axiomatic that practice improves performance.","exJa":"練習が成果を高めることはほぼ自明である。","collocations":["axiomatic truth","become axiomatic","axiomatic assumption"],"synonyms":["self-evident","obvious"],"distractorHint":["疑わしい","例外的な","偶然の"]},
  {"word":"belie","pos":"v","ja":"矛盾する、覆い隠す","level":5,"cat":"academic","ipa":"/bɪˈlaɪ/","ex":"His calm expression belied the anxiety he actually felt.","exJa":"彼の落ち着いた表情は実際に感じていた不安と矛盾していた。","collocations":["belie the fact","belie appearances","belie a claim"],"synonyms":["contradict","misrepresent"],"distractorHint":["証明する","強調する","反映する"]},
  {"word":"bombastic","pos":"adj","ja":"大げさな、誇張した","level":5,"cat":"academic","ipa":"/bɒmˈbæstɪk/","ex":"The politician's bombastic speech impressed few in the audience.","exJa":"その政治家の大げさな演説は聴衆の心をほとんど動かさなかった。","collocations":["bombastic rhetoric","bombastic speech","bombastic tone"],"synonyms":["pompous","grandiose"],"distractorHint":["謙虚な","簡潔な","説得力のある"]},
  {"word":"buttress","pos":"v","ja":"補強する、支持する","level":5,"cat":"academic","ipa":"/ˈbʌtrɪs/","ex":"New evidence was gathered to buttress the original hypothesis.","exJa":"元の仮説を補強するために新たな証拠が集められた。","collocations":["buttress an argument","buttress a claim","further buttress"],"synonyms":["reinforce","support","bolster"],"distractorHint":["弱める","反証する","撤回する"]},
  {"word":"cacophony","pos":"n","ja":"耳障りな音の混合","level":5,"cat":"academic","ipa":"/kəˈkɒfəni/","ex":"The city street was filled with a cacophony of horns and shouting.","exJa":"その街路はクラクションと叫び声の耳障りな不協和音で満ちていた。","collocations":["a cacophony of sound","cacophony of voices","cacophony erupt"],"synonyms":["dissonance","din"],"distractorHint":["静寂","調和","メロディー"]},
  {"word":"capricious","pos":"adj","ja":"気まぐれな","level":5,"cat":"academic","ipa":"/kəˈprɪʃəs/","ex":"The market has become increasingly capricious in recent months.","exJa":"市場はここ数ヶ月でますます気まぐれになっている。","collocations":["capricious weather","capricious behavior","capricious market"],"synonyms":["fickle","erratic","whimsical"],"distractorHint":["安定した","慎重な","忠実な"]},
  {"word":"catalyze","pos":"v","ja":"(変化・反応を)促進する","level":5,"cat":"academic","ipa":"/ˈkætəlaɪz/","ex":"The invention of the printing press catalyzed the spread of literacy.","exJa":"活版印刷の発明は識字率の広がりを促進した。","collocations":["catalyze change","catalyze growth","catalyze a reaction"],"synonyms":["spur","trigger","accelerate"],"distractorHint":["阻止する","抑制する","無効化する"]},
  {"word":"censure","pos":"v","ja":"非難する、譴責する","level":5,"cat":"academic","ipa":"/ˈsɛnʃər/","ex":"The committee voted to censure the senator for his misconduct.","exJa":"委員会はその上院議員を不正行為の理由で非難することを決議した。","collocations":["formally censure","censure a member","face censure"],"synonyms":["condemn","reprimand","denounce"],"distractorHint":["表彰する","擁護する","無視する"]},
  {"word":"chicanery","pos":"n","ja":"ごまかし、詐術","level":5,"cat":"academic","ipa":"/ʃɪˈkeɪnəri/","ex":"Investigators uncovered financial chicanery behind the company's profits.","exJa":"捜査官はその会社の利益の裏にある金融上のごまかしを暴いた。","collocations":["legal chicanery","financial chicanery","expose chicanery"],"synonyms":["deception","trickery","fraud"],"distractorHint":["誠実さ","透明性","正当な手続き"]},
  {"word":"circuitous","pos":"adj","ja":"回りくどい、迂回した","level":5,"cat":"academic","ipa":"/sərˈkjuːɪtəs/","ex":"We took a circuitous route to avoid the city center traffic.","exJa":"私たちは市街中心部の交通を避けるため回りくどい道を通った。","collocations":["circuitous route","circuitous path","circuitous reasoning"],"synonyms":["roundabout","indirect"],"distractorHint":["直接的な","最短の","効率的な"]},
  {"word":"circumscribe","pos":"v","ja":"制限する、限定する","level":5,"cat":"academic","ipa":"/ˈsɜːrkəmskraɪb/","ex":"The new regulations sharply circumscribe the agency's authority.","exJa":"新しい規制はその機関の権限を大幅に制限する。","collocations":["circumscribe authority","circumscribe rights","narrowly circumscribe"],"synonyms":["restrict","limit","confine"],"distractorHint":["拡大する","保障する","無効にする"]},
  {"word":"circumspect","pos":"adj","ja":"慎重な、用心深い","level":5,"cat":"academic","ipa":"/ˈsɜːrkəmspɛkt/","ex":"Investors remained circumspect about the volatile new market.","exJa":"投資家たちはその不安定な新市場について慎重な姿勢を保った。","collocations":["remain circumspect","circumspect approach","circumspect about"],"synonyms":["cautious","prudent","wary"],"distractorHint":["無謀な","楽観的な","率直な"]},
  {"word":"clandestine","pos":"adj","ja":"秘密の、隠密の","level":5,"cat":"academic","ipa":"/klænˈdɛstɪn/","ex":"The two agencies held a clandestine meeting outside the capital.","exJa":"両機関は首都の外で秘密の会合を開いた。","collocations":["clandestine meeting","clandestine operation","clandestine affair"],"synonyms":["covert","secret","surreptitious"],"distractorHint":["公然の","合法的な","公式の"]},
  {"word":"compunction","pos":"n","ja":"良心の呵責、後悔","level":5,"cat":"academic","ipa":"/kəmˈpʌŋkʃən/","ex":"He showed no compunction about canceling the contract abruptly.","exJa":"彼は契約を突然打ち切ることに全く良心の呵責を示さなかった。","collocations":["without compunction","feel compunction","little compunction"],"synonyms":["remorse","guilt","qualm"],"distractorHint":["満足","誇り","確信"]},
  {"word":"conciliatory","pos":"adj","ja":"懐柔的な、融和的な","level":5,"cat":"academic","ipa":"/kənˈsɪliətɔːri/","ex":"The chairman adopted a conciliatory tone to end the labor dispute.","exJa":"議長は労働争議を終わらせるため融和的な口調をとった。","collocations":["conciliatory tone","conciliatory gesture","adopt a conciliatory approach"],"synonyms":["placating","appeasing"],"distractorHint":["対立的な","強硬な","無関心な"]},
  {"word":"condone","pos":"v","ja":"(過ちを)容認する","level":5,"cat":"academic","ipa":"/kənˈdoʊn/","ex":"The board refused to condone the manager's unethical decision.","exJa":"理事会はその管理者の非倫理的な決定を容認することを拒んだ。","collocations":["condone behavior","refuse to condone","implicitly condone"],"synonyms":["tolerate","excuse","overlook"],"distractorHint":["処罰する","非難する","報告する"]},
  {"word":"confound","pos":"v","ja":"困惑させる、混同する","level":5,"cat":"academic","ipa":"/kənˈfaʊnd/","ex":"The unexpected results confounded even the leading experts.","exJa":"予想外の結果は主要な専門家たちさえも困惑させた。","collocations":["confound expectations","confound experts","utterly confound"],"synonyms":["baffle","perplex","bewilder"],"distractorHint":["解明する","確認する","満足させる"]},
  {"word":"congenial","pos":"adj","ja":"気の合う、性に合う","level":5,"cat":"academic","ipa":"/kənˈdʒiːniəl/","ex":"The small seminar offered a congenial atmosphere for debate.","exJa":"その小規模なゼミは議論に適した気楽な雰囲気を提供した。","collocations":["congenial atmosphere","congenial company","congenial environment"],"synonyms":["amiable","pleasant","agreeable"],"distractorHint":["敵対的な","堅苦しい","無関心な"]},
  {"word":"connote","pos":"v","ja":"(言外に)含意する","level":5,"cat":"academic","ipa":"/kəˈnoʊt/","ex":"The word home connotes warmth beyond its literal meaning.","exJa":"「ホーム」という語は文字通りの意味を超えて温かさを含意する。","collocations":["connote meaning","word connote","subtly connote"],"synonyms":["imply","suggest","signify"],"distractorHint":["否定する","明示する","翻訳する"]},
  {"word":"contrite","pos":"adj","ja":"深く後悔した","level":5,"cat":"academic","ipa":"/kənˈtraɪt/","ex":"The CEO issued a contrite apology for the data breach.","exJa":"CEOはデータ漏洩について深く後悔した謝罪を発表した。","collocations":["contrite apology","appear contrite","genuinely contrite"],"synonyms":["remorseful","repentant"],"distractorHint":["傲慢な","冷淡な","反抗的な"]},
  {"word":"copious","pos":"adj","ja":"豊富な、多量の","level":5,"cat":"academic","ipa":"/ˈkoʊpiəs/","ex":"She took copious notes during the three-hour lecture.","exJa":"彼女は3時間の講義中に豊富なノートを取った。","collocations":["copious notes","copious amounts","copious evidence"],"synonyms":["abundant","ample","plentiful"],"distractorHint":["乏しい","簡潔な","不明瞭な"]},
  {"word":"corollary","pos":"n","ja":"(必然的な)結果、系","level":5,"cat":"academic","ipa":"/ˈkɒrəleri/","ex":"Increased funding is a natural corollary of the policy's success.","exJa":"資金の増加はその政策の成功の当然の結果である。","collocations":["a corollary of","direct corollary","natural corollary"],"synonyms":["consequence","byproduct"],"distractorHint":["原因","前提","例外"]},
  {"word":"credulous","pos":"adj","ja":"信じやすい、うのみにする","level":5,"cat":"academic","ipa":"/ˈkrɛdʒələs/","ex":"Credulous investors fell for the fraudulent scheme immediately.","exJa":"信じやすい投資家たちはその詐欺的な計画にすぐに引っかかった。","collocations":["credulous audience","credulous investor","remain credulous"],"synonyms":["gullible","naive"],"distractorHint":["懐疑的な","慎重な","経験豊富な"]},
  {"word":"culpable","pos":"adj","ja":"(過失の)責めを負うべき","level":5,"cat":"academic","ipa":"/ˈkʌlpəbəl/","ex":"The report found the contractor culpable for the structural failure.","exJa":"報告書はその建設業者を構造上の欠陥について責めを負うべきだとした。","collocations":["culpable negligence","hold culpable","legally culpable"],"synonyms":["blameworthy","guilty"],"distractorHint":["無実の","模範的な","被害を受けた"]},
  {"word":"cursory","pos":"adj","ja":"大まかな、ざっとした","level":5,"cat":"academic","ipa":"/ˈkɜːrsəri/","ex":"A cursory glance at the report revealed several errors.","exJa":"報告書をざっと見るだけで複数の誤りが見つかった。","collocations":["cursory glance","cursory review","cursory examination"],"synonyms":["superficial","hasty","perfunctory"],"distractorHint":["徹底的な","慎重な","詳細な"]},
  {"word":"debilitate","pos":"v","ja":"衰弱させる","level":5,"cat":"academic","ipa":"/dɪˈbɪlɪteɪt/","ex":"The chronic illness gradually debilitated her ability to work.","exJa":"その慢性疾患は彼女の仕事をする能力を徐々に衰弱させた。","collocations":["debilitating illness","debilitate the economy","severely debilitate"],"synonyms":["weaken","enfeeble","incapacitate"],"distractorHint":["活性化する","治療する","強化する"]},
  {"word":"decorum","pos":"n","ja":"礼儀正しさ、端正","level":5,"cat":"academic","ipa":"/dɪˈkɔːrəm/","ex":"The judge insisted on strict decorum inside the courtroom.","exJa":"裁判官は法廷内で厳格な礼儀正しさを求めた。","collocations":["maintain decorum","breach of decorum","strict decorum"],"synonyms":["propriety","etiquette"],"distractorHint":["混乱","無礼","装飾"]},
  {"word":"demagogue","pos":"n","ja":"扇動政治家","level":5,"cat":"academic","ipa":"/ˈdɛməɡɒɡ/","ex":"Historians warned that the movement could be hijacked by a demagogue.","exJa":"歴史家たちはその運動が扇動政治家に乗っ取られる恐れがあると警告した。","collocations":["rise of a demagogue","populist demagogue","denounce as a demagogue"],"synonyms":["rabble-rouser","agitator"],"distractorHint":["改革者","調停者","学者"]},
  {"word":"denigrate","pos":"v","ja":"けなす、中傷する","level":5,"cat":"academic","ipa":"/ˈdɛnɪɡreɪt/","ex":"The campaign was criticized for trying to denigrate its opponents.","exJa":"その選挙運動は対立候補を中傷しようとしたと批判された。","collocations":["denigrate an opponent","denigrate the work","unfairly denigrate"],"synonyms":["disparage","belittle","malign"],"distractorHint":["称賛する","支持する","無視する"]},
  {"word":"deplete","pos":"v","ja":"枯渇させる","level":5,"cat":"academic","ipa":"/dɪˈpliːt/","ex":"Years of overfishing have severely depleted the coastal fish stocks.","exJa":"長年の過剰漁獲により沿岸の魚資源は著しく枯渇した。","collocations":["deplete resources","deplete reserves","rapidly deplete"],"synonyms":["exhaust","drain","use up"],"distractorHint":["補充する","保存する","増加させる"]}
