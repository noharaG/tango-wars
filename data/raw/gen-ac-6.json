  {"word":"output","pos":"n","ja":"出力、生産量","level":5,"cat":"academic","ipa":"/ˈaʊtpʊt/","ex":"The generator's output dropped during the power surge.","exJa":"電力サージの間、発電機の出力が下がった。","collocations":["power output","maximize output"],"synonyms":["yield","production"],"distractorHint":["入力","産出者","出口"]},
