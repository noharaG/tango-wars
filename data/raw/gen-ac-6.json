[
  {"word":"negligible","pos":"adj","ja":"無視できるほど小さい","level":5,"cat":"academic","ipa":"/ˈneɡlɪdʒəbl/","ex":"The measurement error was negligible compared to the signal.","exJa":"測定誤差は信号に比べて無視できるほど小さかった。","collocations":["negligible amount","negligible effect"],"synonyms":["insignificant","trivial","minimal"],"distractorHint":["無視できない","怠慢な","否定的な"]},
  {"word":"negate","pos":"v","ja":"無効にする、否定する","level":5,"cat":"academic","ipa":"/nɪˈɡeɪt/","ex":"A single counterexample can negate the whole theory.","exJa":"一つの反例が理論全体を無効にすることがある。","collocations":["negate the effect","negate an argument"],"synonyms":["nullify","invalidate","cancel"],"distractorHint":["交渉する","無視する","強調する"]},
  {"word":"neutral","pos":"adj","ja":"中立の、中性の","level":5,"cat":"academic","ipa":"/ˈnuːtrəl/","ex":"The engineer remained neutral during the design dispute.","exJa":"技術者は設計に関する論争で中立を保った。","collocations":["remain neutral","politically neutral"],"synonyms":["impartial","unbiased"],"distractorHint":["積極的な","有害な","中心の"]},
  {"word":"nevertheless","pos":"adv","ja":"それにもかかわらず","level":5,"cat":"academic","ipa":"/ˌnevərðəˈles/","ex":"The prototype failed twice; nevertheless, the team continued testing.","exJa":"試作品は二度失敗したが、それでもチームは試験を続けた。","collocations":["but nevertheless","nevertheless, it"],"synonyms":["nonetheless","however","still"],"distractorHint":["それゆえに","その結果","同様に"]},
  {"word":"norm","pos":"n","ja":"標準、基準","level":5,"cat":"academic","ipa":"/nɔːrm/","ex":"Working overtime became the norm in that department.","exJa":"残業がその部署では当たり前になった。","collocations":["social norm","industry norm"],"synonyms":["standard","convention"],"distractorHint":["規範から外れること","北","普通でないこと"]},
  {"word":"notion","pos":"n","ja":"概念、考え","level":5,"cat":"academic","ipa":"/ˈnoʊʃən/","ex":"He rejected the notion that failure was always negative.","exJa":"彼は失敗が常に悪いという考えを否定した。","collocations":["the notion that","vague notion"],"synonyms":["idea","concept"],"distractorHint":["通知","運動","感情"]},
  {"word":"notwithstanding","pos":"phr","ja":"にもかかわらず","level":5,"cat":"academic","ipa":"/ˌnɒtwɪθˈstændɪŋ/","ex":"Notwithstanding the delays, the project finished on budget.","exJa":"遅延にもかかわらず、プロジェクトは予算内で完了した。","collocations":["notwithstanding this","law notwithstanding"],"synonyms":["despite","regardless of"],"distractorHint":["そのために","同時に","立っている状態で"]},
  {"word":"novel","pos":"adj","ja":"新規の、独創的な","level":5,"cat":"academic","ipa":"/ˈnɒvəl/","ex":"The paper proposes a novel algorithm for path planning.","exJa":"この論文は経路計画のための新しいアルゴリズムを提案する。","collocations":["novel approach","novel method"],"synonyms":["innovative","original"],"distractorHint":["小説の","古い","退屈な"]},
  {"word":"nuance","pos":"n","ja":"微妙な違い","level":5,"cat":"academic","ipa":"/ˈnuːɑːns/","ex":"Translating technical nuance between languages is often quite difficult.","exJa":"技術的な微妙な違いを言語間で翻訳するのはしばしば非常に難しい。","collocations":["subtle nuance","capture the nuance"],"synonyms":["subtlety"],"distractorHint":["核","騒音","明確な違い"]},
  {"word":"nucleus","pos":"n","ja":"核、中心部","level":5,"cat":"academic","ipa":"/ˈnuːkliəs/","ex":"The control unit forms the nucleus of the whole system.","exJa":"制御ユニットは全システムの中核をなす。","collocations":["nucleus of","cell nucleus"],"synonyms":["core","center"],"distractorHint":["迷惑","無効にすること","周辺部"]},
  {"word":"nullify","pos":"v","ja":"無効にする","level":5,"cat":"academic","ipa":"/ˈnʌlɪfaɪ/","ex":"A single design flaw can nullify years of research.","exJa":"一つの設計上の欠陥が何年もの研究を無効にしうる。","collocations":["nullify an effect","nullify a contract"],"synonyms":["negate","invalidate","void"],"distractorHint":["強化する","数え上げる","確認する"]},
