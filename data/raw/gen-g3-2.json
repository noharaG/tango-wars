[
  {"word":"consequence","pos":"n","ja":"結果、影響","level":3,"cat":"general","ipa":"ˈkɒnsɪkwəns","ex":"Every action has a consequence, whether good or bad.","exJa":"すべての行動には結果が伴う、良くも悪くも。","collocations":["as a consequence of","suffer the consequences","far-reaching consequences"],"synonyms":["result","outcome"],"distractorHint":["原因","目的","過程"]},
