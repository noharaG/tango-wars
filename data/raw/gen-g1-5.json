[
  {"word":"say","pos":"v","ja":"言う","level":1,"cat":"general","ipa":"/seɪ/","ex":"Please say your name clearly so everyone can hear you.","exJa":"皆に聞こえるようにはっきり名前を言ってください。","collocations":["say hello","say sorry","say a word"],"synonyms":["tell","speak","mention"],"distractorHint":["聞く","書く","叫ぶ"]},
