  {"word":"impede","pos":"v","ja":"妨げる","level":4,"cat":"general","ipa":"ɪmˈpiːd","ex":"Heavy traffic impeded our progress across the city.","exJa":"激しい交通が市内での移動の進行を妨げた。","collocations":["impede progress","impede growth"],"synonyms":["hinder","obstruct"],"distractorHint":["促進する","許可する","報告する"]},
  {"word":"imperative","pos":"adj","ja":"必須の、絶対必要な","level":4,"cat":"general","ipa":"ɪmˈpɛrətɪv","ex":"It is imperative that we act before the deadline.","exJa":"締め切り前に行動することが絶対に必要だ。","collocations":["imperative to","absolutely imperative"],"synonyms":["essential","crucial"],"distractorHint":["任意の","不可能な","望ましくない"]},
  {"word":"implicit","pos":"adj","ja":"暗黙の","level":4,"cat":"general","ipa":"ɪmˈplɪsɪt","ex":"There was an implicit understanding between the two leaders.","exJa":"二人の指導者の間には暗黙の了解があった。","collocations":["implicit trust","implicit assumption"],"synonyms":["unspoken","tacit"],"distractorHint":["明示的な","強制的な","不確かな"]},
