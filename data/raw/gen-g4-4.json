[
  {"word":"hone","pos":"v","ja":"磨く、鍛える","level":4,"cat":"general","ipa":"hoʊn","ex":"She spent years honing her negotiation skills.","exJa":"彼女は何年もかけて交渉スキルを磨いた。","collocations":["hone skills","hone one's craft"],"synonyms":["sharpen","refine"],"distractorHint":["無視する","誇張する","放棄する"]},
  {"word":"hedge","pos":"v","ja":"リスクを避ける、言葉を濁す","level":4,"cat":"general","ipa":"hɛdʒ","ex":"The company hedged its bets by investing in multiple markets.","exJa":"その会社は複数の市場に投資してリスクを分散した。","collocations":["hedge against","hedge one's bets"],"synonyms":["protect","safeguard"],"distractorHint":["全力を尽くす","誇張する","放棄する"]},
  {"word":"hindrance","pos":"n","ja":"妨げ、障害","level":4,"cat":"general","ipa":"ˈhɪndrəns","ex":"Lack of funding proved to be a major hindrance to the project.","exJa":"資金不足がその計画の大きな妨げとなった。","collocations":["a hindrance to","prove a hindrance"],"synonyms":["obstacle","impediment"],"distractorHint":["助け","許可","報酬"]},
  {"word":"holistic","pos":"adj","ja":"全体論的な","level":4,"cat":"general","ipa":"hoʊˈlɪstɪk","ex":"The clinic takes a holistic approach to patient care.","exJa":"その診療所は患者ケアに全体論的なアプローチをとる。","collocations":["holistic approach","holistic view"],"synonyms":["comprehensive","integrated"],"distractorHint":["部分的な","理論的な","伝統的な"]},
  {"word":"hubris","pos":"n","ja":"傲慢、過度の自信","level":4,"cat":"general","ipa":"ˈhjuːbrɪs","ex":"His hubris eventually led to the company's downfall.","exJa":"彼の傲慢さが結局は会社の破滅を招いた。","collocations":["sheer hubris","the hubris of"],"synonyms":["arrogance","conceit"],"distractorHint":["謙虚さ","恐怖","後悔"]},
  {"word":"hyperbole","pos":"n","ja":"誇張表現","level":4,"cat":"general","ipa":"haɪˈpɜːrbəli","ex":"Calling it the best meal ever was pure hyperbole.","exJa":"それを史上最高の料理と呼ぶのは単なる誇張だった。","collocations":["pure hyperbole","use hyperbole"],"synonyms":["exaggeration","overstatement"],"distractorHint":["皮肉","直喩","控えめな表現"]},
  {"word":"hypocrisy","pos":"n","ja":"偽善","level":4,"cat":"general","ipa":"hɪˈpɒkrəsi","ex":"Critics accused the politician of blatant hypocrisy.","exJa":"批評家たちはその政治家を露骨な偽善だと非難した。","collocations":["blatant hypocrisy","accuse of hypocrisy"],"synonyms":["duplicity","insincerity"],"distractorHint":["誠実さ","謙虚さ","無関心"]},
  {"word":"hypothetical","pos":"adj","ja":"仮説の、仮定の","level":4,"cat":"general","ipa":"ˌhaɪpəˈθɛtɪkəl","ex":"Let's consider a hypothetical scenario for a moment.","exJa":"少しの間、仮定のシナリオを考えてみよう。","collocations":["hypothetical situation","purely hypothetical"],"synonyms":["theoretical","speculative"],"distractorHint":["確定した","歴史的な","現実的な"]},
  {"word":"iconic","pos":"adj","ja":"象徴的な、代表的な","level":4,"cat":"general","ipa":"aɪˈkɒnɪk","ex":"The bridge has become an iconic symbol of the city.","exJa":"その橋はその都市を象徴する存在になった。","collocations":["iconic image","become iconic"],"synonyms":["emblematic","legendary"],"distractorHint":["無名の","一時的な","矛盾した"]},
